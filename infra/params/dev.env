#!/usr/bin/env bash
# Environment parameters for dev
# Source this file: source ./params/dev.env

export ENV_NAME="dev"
export PROJECT="chatbot"
export LOCATION="indonesiacentral"
export LOCATION_APPS="southeastasia"       # For services not available in indonesiacentral (ACR, AI, Container Apps)
export RESOURCE_GROUP="project-lab-${ENV_NAME}"

# Networking
export VNET_NAME="${PROJECT}-${ENV_NAME}-vnet"
export VNET_PREFIX="10.0.0.0/16"
export SUBNET_VM="vm-subnet"
export SUBNET_VM_PREFIX="10.0.1.0/24"
export SUBNET_GPU="gpu-subnet"
export SUBNET_GPU_PREFIX="10.0.2.0/24"
export SUBNET_APPS="apps-subnet"
export SUBNET_APPS_PREFIX="10.0.3.0/27"

# Container Registry
export ACR_NAME="${PROJECT}${ENV_NAME}acr7080"

# Key Vault
export KV_NAME="${PROJECT}-${ENV_NAME}-kv"

# VM — Qdrant + Embedding
export VM_NAME="${PROJECT}-${ENV_NAME}-vm"
export VM_SIZE="Standard_D8s_v5"
export VM_IMAGE="Ubuntu2204"
export VM_ADMIN="azureuser"
export VM_NSG="${PROJECT}-${ENV_NAME}-vm-nsg"

# GPU VM — vLLM
export VM_GPU_NAME="${PROJECT}-${ENV_NAME}-gpu"
export VM_GPU_SIZE="Standard_NV36ads_A10_v5"
export VM_GPU_NSG="${PROJECT}-${ENV_NAME}-gpu-nsg"

# AI Foundry
export AI_ACCOUNT_NAME="${PROJECT}-${ENV_NAME}-ai"
export EMBEDDING_MODEL="text-embedding-3-small"
export EMBEDDING_DEPLOYMENT="text-embedding-3-small"

# Document Intelligence (disconnected container on VM)
export DOC_INTEL_NAME="${PROJECT}-${ENV_NAME}-docintel"
export DOC_INTEL_IMAGE="mcr.microsoft.com/azure-cognitive-services/form-recognizer/layout-3.0:latest"
export DOC_INTEL_PORT="5050"
export DOC_INTEL_LICENSE_DIR="/data/doc-intel/license"
export DOC_INTEL_OUTPUT_DIR="/data/doc-intel/output"

# Container Apps
export CAE_NAME="${PROJECT}-${ENV_NAME}-env"
export CA_BACKEND_NAME="${PROJECT}-${ENV_NAME}-backend"
export CA_FRONTEND_NAME="${PROJECT}-${ENV_NAME}-frontend"

# vLLM
export VLLM_MODEL="Qwen/Qwen3.5-9B"
export VLLM_PORT="8000"

# Qdrant
export QDRANT_PORT="6333"
export QDRANT_GRPC_PORT="6334"
export QDRANT_COLLECTION="documents"
